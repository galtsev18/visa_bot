# =============================================================================
# REQUIRED IN .ENV — only these are read from .env; rest from spreadsheet "Settings" sheet
# =============================================================================
# Google Sheets ID from URL: https://docs.google.com/spreadsheets/d/{GOOGLE_SHEETS_ID}/edit
GOOGLE_SHEETS_ID=your_spreadsheet_id_here
# Path to Google Service Account credentials JSON (from Google Cloud Console)
GOOGLE_CREDENTIALS_PATH=./credentials.json

# All other settings go in the spreadsheet "Settings" sheet (columns: key, value):
# TELEGRAM_BOT_TOKEN, TELEGRAM_MANAGER_CHAT_ID, FACILITY_ID, REFRESH_INTERVAL,
# SHEETS_REFRESH_INTERVAL, CACHE_TTL, ROTATION_COOLDOWN, AIS_REQUEST_DELAY_SEC,
# AIS_RATE_LIMIT_BACKOFF_SEC, CAPTCHA_2CAPTCHA_API_KEY
