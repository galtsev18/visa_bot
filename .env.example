# Google Sheets Configuration
# Get your Google Sheets ID from the URL: https://docs.google.com/spreadsheets/d/{GOOGLE_SHEETS_ID}/edit
GOOGLE_SHEETS_ID=your_spreadsheet_id_here

# Path to Google Service Account credentials JSON file
# Download from Google Cloud Console: https://console.cloud.google.com/iam-admin/serviceaccounts
GOOGLE_CREDENTIALS_PATH=./credentials.json

# Telegram Bot Configuration
# Create a bot via @BotFather on Telegram to get the token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Manager's Telegram Chat ID (hardcoded - notifications will be sent here)
# Get your chat ID by messaging @userinfobot on Telegram
TELEGRAM_MANAGER_CHAT_ID=your_manager_chat_id_here

# Visa System Configuration
# Facility ID is hardcoded (same for all users)
FACILITY_ID=134

# Monitoring Configuration
# Seconds between checking each user
REFRESH_INTERVAL=3

# Seconds between refreshing user list from Google Sheets
SHEETS_REFRESH_INTERVAL=300

# Cache time-to-live in seconds (how long cached dates remain valid)
CACHE_TTL=60

# Rotation cooldown in seconds (minimum time before same user is checked again)
ROTATION_COOLDOWN=30

# NOTE: User credentials (email, password, schedule_id, country_code) are stored in Google Sheets, not in .env
# For multi-user mode (monitor command), all user data comes from Google Sheets
# EMAIL=your.email@example.com (only for single-user bot command)
# PASSWORD=your_password (only for single-user bot command)
# COUNTRY_CODE=kz
# SCHEDULE_ID=your_schedule_id
# REFRESH_DELAY=3
